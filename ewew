<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Форма</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            background:#f5f5f5;
            display:flex;
            justify-content:center;
            align-items:center;
            height:100vh;
            margin:0;
        }

        .card{
            background:#fff;
            padding:30px;
            border-radius:15px;
            width:350px;
            box-shadow:0 5px 20px rgba(0,0,0,.15);
        }

        h2{
            margin-top:0;
            text-align:center;
        }

        textarea{
            width:100%;
            height:120px;
            padding:10px;
            box-sizing:border-box;
            resize:none;
            font-size:16px;
        }

        button{
            width:100%;
            margin-top:15px;
            padding:12px;
            border:none;
            background:#0088cc;
            color:white;
            font-size:16px;
            border-radius:8px;
            cursor:pointer;
        }

        button:hover{
            background:#0070aa;
        }

        #status{
            margin-top:15px;
            text-align:center;
            font-weight:bold;
        }
    </style>
</head>

<body>

<div class="card">

    <h2>Отправить сообщение</h2>

    <textarea id="gift" placeholder="Введите текст..."></textarea>

    <button onclick="sendMail()">Отправить</button>

    <div id="status"></div>

</div>

<script>

const TOKEN = "ВСТАВЬ_СЮДА_ТОКЕН_БОТА";
const CHAT_ID = "ВСТАВЬ_СЮДА_CHAT_ID";

async function sendMail(){

    const text = document.getElementById("gift").value.trim();

    if(!text){
        document.getElementById("status").innerHTML="🌸 Напишите сообщение!";
        return;
    }

    try{

        const response = await fetch(
            `https://api.telegram.org/bot${TOKEN}/sendMessage`,
            {
                method:"POST",
                headers:{
                    "Content-Type":"application/json"
                },
                body:JSON.stringify({
                    chat_id:CHAT_ID,
                    text:`🌸 Новое сообщение\n\n💖 ${text}`
                })
            }
        );

        if(response.ok){

            document.getElementById("status").innerHTML="❤️ Спасибо!";
            document.getElementById("gift").value="";

        }else{

            document.getElementById("status").innerHTML="❌ Ошибка отправки";

        }

    }catch(error){

        document.getElementById("status").innerHTML="❌ Ошибка соединения";

    }

}

</script>

</body>
</html>
